# Public site URL — used for Open Graph / social link previews (no trailing slash)

VITE_SITE_URL=https://black-rose-six.vercel.app



# Supabase — required for all DB / auth calls

VITE_SUPABASE_URL=https://your-project.supabase.co

VITE_SUPABASE_ANON_KEY=your-anon-key



# Server-side Supabase (OAuth member upsert) — optional if anon RLS allows writes

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key



# Discord OAuth2 — https://discord.com/developers/applications

VITE_DISCORD_CLIENT_ID=1513525139151781970

DISCORD_CLIENT_SECRET=your-discord-client-secret

# OAuth callback is derived from the browser URL ({origin}/auth/callback) — no redirect env var needed.

# Register each deployment URL in Discord → OAuth2 → Redirects, e.g.:

#   http://localhost:5173/auth/callback

#   https://black-rose-six.vercel.app/auth/callback



# Discord server invite shown on waitlist / onboarding

VITE_DISCORD_SERVER_INVITE=https://discord.com/invite/Epe4aDdt8N



# Riot Sign On (RSO) + Valorant API — server secrets only; never expose in the browser bundle.
# Register redirect URI in the Riot Developer Portal, e.g.:
#   http://localhost:5173/auth/riot/callback
#   https://black-rose-six.vercel.app/auth/riot/callback
VITE_RIOT_RSO_CLIENT_ID=your-rso-client-id
RIOT_RSO_CLIENT_ID=your-rso-client-id
RIOT_RSO_CLIENT_SECRET=your-rso-client-secret
RIOT_API_KEY=your-development-riot-api-key
# Regional cluster for /riot/account/v1/accounts/me — americas | europe | asia
RIOT_ACCOUNT_CLUSTER=asia



# Admin console (operators only — not linked in the public UI)

# Sign in at /login?console=1 with credentials from admin_accounts (see docs/sql/admin_accounts.sql).

