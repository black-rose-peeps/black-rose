# Public site URL — used for Open Graph / social link previews (no trailing slash)

VITE_SITE_URL=https://blackrose.asia



# Supabase — required for all DB / auth calls

VITE_SUPABASE_URL=https://your-project.supabase.co

VITE_SUPABASE_ANON_KEY=your-anon-key



# Server-side Supabase (OAuth member upsert) — optional if anon RLS allows writes

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key



# Discord OAuth2 — https://discord.com/developers/applications
# Scopes include guilds.members.read so existing ROSE holders verify on first sign-in.

VITE_DISCORD_CLIENT_ID=1513525139151781970

DISCORD_CLIENT_SECRET=your-discord-client-secret

# OAuth callback defaults to {browser origin}/auth/callback — do NOT set localhost here when
# testing on a phone (Discord would redirect to the phone's localhost, not your PC).
# For mobile dev, either:
#   A) Open http://YOUR-LAN-IP:5173 on your phone and register that /auth/callback in Discord, or
#   B) Use an HTTPS tunnel (recommended):
#   VITE_DISCORD_REDIRECT_URI=https://your-subdomain.trycloudflare.com/auth/callback

# Open the tunnel URL on your phone (not the 192.168.x.x address) and register the same
# redirect URI in Discord → OAuth2 → Redirects, e.g.:

#   http://localhost:3000/auth/callback          (desktop dev)
#   https://your-subdomain.trycloudflare.com/auth/callback   (mobile dev via tunnel)
#   https://blackrose.asia/auth/callback           (production)



# Discord server invite shown on waitlist / onboarding
VITE_DISCORD_SERVER_INVITE=https://discord.com/invite/blackrosehq



# Waitlist verification channel (official Black Rose #✅ㆍverification)
# Use the real ✅ emoji — not Discord markdown like :white_check_mark:
VITE_DISCORD_VERIFICATION_CHANNEL_URL=https://discord.com/channels/1193921905795792906/1196472627439599716
VITE_DISCORD_VERIFICATION_CHANNEL_LABEL=✅ㆍverification
# React-to-get-role channel (ROSE / tournament / Valorant) — waitlist step 3
VITE_DISCORD_TOURNA_ROLES_CHANNEL_URL=https://discord.com/channels/1193921905795792906/1517262068615614545
VITE_DISCORD_TOURNA_ROLES_CHANNEL_LABEL=tourna-roles



# Discord bot — server-side only (never VITE_).
# Production: Cloudflare Worker (workers/discord-sync) — SYNC_BATCH_SIZE max ~22 on Workers Free
# Local optional: npm run discord-bot (instant Gateway sync while testing)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=1193921905795792906

# Required for Worker + login fallback — Developer Mode → right-click role → Copy Role ID
DISCORD_ROSE_ROLE_ID=1465647773658517660
DISCORD_ROSE_ROLE_NAME=ROSE

# Admin-triggered immediate Worker sync (POST /sync; server-side only)
DISCORD_SYNC_WORKER_URL=https://blackrose-discord-sync.domasigreoner.workers.dev
DISCORD_SYNC_SECRET=your-worker-sync-secret



# Admin console (operators only — not linked in the public UI)
# Sign in at /login?console=1 with credentials from admin_accounts (see docs/sql/admin_accounts.sql).

