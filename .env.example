# Supabase — required for all DB / auth calls
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mock admin seed (development only)
# These seed an in-memory admin credential so you can log in to the Admin Console
# without a Supabase Auth account. Remove once real auth is wired.
VITE_ADMIN_SEED_USER=admin
VITE_ADMIN_SEED_PASS=changeme
