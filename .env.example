# Public site URL — used for Open Graph / social link previews (no trailing slash)

VITE_SITE_URL=https://black-rose-six.vercel.app



# Supabase — required for all DB / auth calls

VITE_SUPABASE_URL=https://your-project.supabase.co

VITE_SUPABASE_ANON_KEY=your-anon-key



# Server-side Supabase (OAuth member upsert) — optional if anon RLS allows writes

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key



# Discord OAuth2 — https://discord.com/developers/applications
# Scopes include guilds.members.read so existing ROSE holders verify on first sign-in.

VITE_DISCORD_CLIENT_ID=1513525139151781970

DISCORD_CLIENT_SECRET=your-discord-client-secret

# OAuth callback is derived from the browser URL ({origin}/auth/callback) — no redirect env var needed.

# Register each deployment URL in Discord → OAuth2 → Redirects, e.g.:

#   http://localhost:5173/auth/callback
#   https://black-rose-six.vercel.app/auth/callback



# Discord server invite shown on waitlist / onboarding

# Test server: https://discord.gg/8ANEBjp3p2
# Production:  https://discord.com/invite/blackrosehq
VITE_DISCORD_SERVER_INVITE=https://discord.gg/8ANEBjp3p2



# Waitlist verification channel (guild id + channel id from Discord)
VITE_DISCORD_VERIFICATION_CHANNEL_URL=https://discord.com/channels/1513607330250358995/your-verification-channel-id
VITE_DISCORD_VERIFICATION_CHANNEL_LABEL=✅ㆍverification



# Discord bot — server-side only (never VITE_). Gateway worker syncs ROSE role → Supabase.
# 1. Developer Portal → Bot → enable "Server Members Intent"
# 2. Reset Token → set DISCORD_BOT_TOKEN below
# 3. Invite bot to your guild (bot scope)
# 4. Run: npm run discord-bot  (keep running alongside the web app)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=1513607330250358995

# Prefer role ID (Developer Mode → right-click role → Copy Role ID). Falls back to name lookup:
DISCORD_ROSE_ROLE_ID=
DISCORD_ROSE_ROLE_NAME=ROSE



# Admin console (operators only — not linked in the public UI)
# Sign in at /login?console=1 with credentials from admin_accounts (see docs/sql/admin_accounts.sql).

